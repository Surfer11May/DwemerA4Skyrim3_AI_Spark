#!/bin/bash
# 1. Update and add deadsnakes PPA for Python 3.10
apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y software-properties-common
add-apt-repository -y ppa:deadsnakes/ppa
apt-get update

# 2. Install Python 3.10 and Dev tools
DEBIAN_FRONTEND=noninteractive apt-get install -y python3.10 python3.10-venv python3.10-dev

# 3. Set Python 3.10 as the default
update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1

# 4. Install dependencies via module (AVOIDS /project path error)
python3 -m pip install --upgrade pip
